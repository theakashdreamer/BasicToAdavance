<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.BasicToAdavance" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/antique_white</item>
        <item name="colorPrimaryDark">@color/alice_blue</item>
        <item name="colorAccent">@color/beige</item>
        <!-- Customize your theme here. -->
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>

    </style>

    <style name="assessment_toolbar_style" parent="@style/Widget.AppCompat.Toolbar">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">?attr/actionBarSize</item>
        <item name="android:background">@color/azure</item>
        <item name="android:minHeight">?attr/actionBarSize</item>
        <item name="android:elevation">4dp</item>
    </style>

    <style name="Theme.BasicToAdavance.NoActionBar" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Disable ActionBar -->
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>

        <!-- Primary Purple -->
        <item name="colorPrimary">#A259FF</item>
        <item name="colorPrimaryVariant">#6C5CE7</item>
        <item name="colorOnPrimary">#FFFFFF</item>

        <!-- Secondary Mint -->
        <item name="colorSecondary">#00FFB3</item>
        <item name="colorSecondaryVariant">#00E6A8</item>
        <item name="colorOnSecondary">#FFFFFF</item>

        <!-- Background and Surface -->
        <item name="android:colorBackground">#F3F0FF</item>
        <item name="colorSurface">#FFFFFF</item>
        <item name="colorOnSurface">#333333</item>

        <!-- Status Bar and Navigation Bar -->
        <item name="android:statusBarColor">#74A259FF</item>
        <item name="android:navigationBarColor">#EFEBF3</item>
    </style>


    <style name="Theme.BasicToAdavance.AppBarOverlay" parent="ThemeOverlay.AppCompat.Dark.ActionBar" />

    <style name="Theme.BasicToAdavance.PopupOverlay" parent="ThemeOverlay.AppCompat.Light" />

    <style name="AppTheme" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary: Light Purple -->
        <item name="colorPrimary">#83A259FF</item>
        <item name="colorPrimaryVariant">#8D6C5CE7</item>
        <item name="colorOnPrimary">#FFFFFF</item>

        <!-- Secondary: Mint Green Accent -->
        <item name="colorSecondary">#00FFB3</item>
        <item name="colorSecondaryVariant">#00E6A8</item>
        <item name="colorOnSecondary">#FFFFFF</item>

        <!-- Background: Soft Lavender -->
        <item name="android:colorBackground">#F3F0FF</item>
        <item name="colorSurface">#FFFFFF</item>
        <item name="colorOnSurface">#333333</item>

        <!-- Status Bar: Match purple background -->
        <item name="android:statusBarColor">#95A259FF</item>

        <!-- Navigation Bar: Light Purple -->
        <item name="android:navigationBarColor">#4FA259FF</item>

        <!-- Custom Text Colors -->
        <item name="android:textColorPrimary">#333333</item>
        <item name="android:textColorSecondary">#777777</item>
    </style>

    <style name="AppThemeDarkAction" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- Primary color: Light Purple -->
        <item name="colorPrimary">#7AA259FF</item>
        <item name="colorPrimaryVariant">#6B6C5CE7</item>
        <item name="colorOnPrimary">#FFFFFF</item>

        <!-- Secondary color: Mint Accent -->
        <item name="colorSecondary">#00FFB3</item>
        <item name="colorSecondaryVariant">#00E6A8</item>
        <item name="colorOnSecondary">#2E1F1F</item>

        <!-- Background and Surface -->
        <item name="android:colorBackground">#F3F0FF</item>
        <item name="colorSurface">#FFFFFF</item>
        <item name="colorOnSurface">#333333</item>

        <!-- Status Bar -->
        <item name="android:statusBarColor">#81A259FF</item>

        <!-- Navigation Bar -->
        <item name="android:navigationBarColor">#00A259FF</item>

        <!-- Custom Text Colors -->
        <item name="android:textColorPrimary">#333333</item>
        <item name="android:textColorSecondary">#777777</item>

    </style>


</resources>